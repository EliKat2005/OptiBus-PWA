# ==========================================
# CONFIGURACIÓN DE ENTORNO (DEVSECOPS)
# Renombra este archivo a .env en el servidor
# ==========================================

# --- Base de Datos (PostGIS) ---
POSTGRES_DB=optibus_prod
POSTGRES_USER=optibus_admin
# NUNCA uses la contraseña por defecto en la VM. Cámbiala.
POSTGRES_PASSWORD=CHANGEME_SECURE_PASSWORD
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Servidor Web (Caddy Proxy & SSL) ---
# En Azure, pon aquí tu dominio (ej: app.midominio.com). 
# Caddy generará automáticamente el certificado HTTPS.
# ADVERTENCIA: Si dejas localhost, solo funcionará con HTTP sin SSL real.
DOMAIN=localhost

# --- API Backend ---
ENABLE_BUS_SIMULATOR=false

# API Key para autenticación de endpoints GPS (mín. 16 caracteres)
# Si no se define, los endpoints /api/gps/* no requerirán autenticación (inseguro en producción)
# Genera una key segura: openssl rand -base64 32
OPTIBUS_API_KEY=

# Nivel de logging: DEBUG, INFO, WARNING, ERROR
# Usar WARNING en producción para evitar fuga de datos GPS en logs
LOG_LEVEL=INFO

# Orígenes permitidos para CORS
# En producción, usa el dominio real (ej: https://app.midominio.com)
CORS_ORIGINS=http://localhost:80,http://localhost,http://127.0.0.1
