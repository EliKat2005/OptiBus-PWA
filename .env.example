# ==========================================
# CONFIGURACIÓN DE ENTORNO (DEVSECOPS)
# Renombra este archivo a .env en el servidor
# ==========================================

# --- Base de Datos (PostGIS) ---
POSTGRES_DB=optibus_prod
POSTGRES_USER=optibus_admin
# NUNCA uses la contraseña por defecto en la VM. Cámbiala.
POSTGRES_PASSWORD=CHANGEME_SECURE_PASSWORD
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Servidor Web (Caddy Proxy & SSL) ---
# En Azure, pon aquí tu dominio (ej: app.midominio.com). 
# Caddy generará automáticamente el certificado HTTPS.
DOMAIN=localhost

# --- API Backend ---
ENABLE_BUS_SIMULATOR=false
# Dejar vacío en producción
# API_RELOAD=--reload