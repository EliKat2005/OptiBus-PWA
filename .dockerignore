# ==========================================
# DevSecOps v4.0: Docker Ignore para build seguro
# ==========================================

# ── Entorno y Secretos ──
.env
.env.*
*.key
*.pem
*.crt
secrets/

# ── Git ──
.git
.gitignore
.gitattributes
.github
.gitlab-ci.yml

# ── Documentación ──
docs/
*.md
README*

# ── Tests ──
**/tests/
**/test_*
**/*_test.*
.pytest_cache/
.coverage
htmlcov/

# ── Desarrollo ──
.venv/
venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.ruff_cache/
.mypy_cache/
.vscode/
.idea/
*.swp
*.swo
*~

# ── Scripts de despliegue (no necesarios en imagen) ──
scripts/
deploy.sh
Caddyfile
compose.yaml
compose.override.yaml

# ── Frontend (servido por Caddy, no por API) ──
frontend/

# ── Mobile Driver (APK, no relevante en backend) ──
mobile-driver/

# ── Config de deploy ──
deploy/

# ── Datos locales y backups ──
*.tar.gz
*.zip
backups/
.deploy_backups/
backend/data/

# ── OS junk ──
.DS_Store
Thumbs.db