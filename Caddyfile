:8080 {
    # DevSecOps: Implementación de cabeceras de seguridad fundamentales
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "no-referrer-when-downgrade"
        # Política de Seguridad de Contenido (CSP) para prevenir XSS y data injection
        Content-Security-Policy "default-src 'self'; script-src 'self' https://unpkg.com 'unsafe-inline'; style-src 'self' https://unpkg.com 'unsafe-inline'; img-src 'self' data: https://*.tile.openstreetmap.org https://cdn-icons-png.flaticon.com https://cdn.iconscout.com; connect-src 'self' ws: wss:; font-src 'self';"
        # Ocultar versión del servidor
        -Server
    }

    # 1. Servir el Frontend estático PWA
    root * /srv/frontend
    file_server

    # 2. Redirigir peticiones API al backend de FastAPI
    handle /health {
        reverse_proxy api:8000
    }
    
    handle /api/* {
        reverse_proxy api:8000
    }

    # 3. Redirigir WebSockets
    handle /ws {
        reverse_proxy api:8000
    }

    # 4. Políticas de logs para auditoría de accesos
    log {
        output file /var/log/caddy/access.log
        format json
    }
}